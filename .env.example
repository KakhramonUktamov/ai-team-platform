# LLM Provider (openai or anthropic)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database
DATABASE_URL=postgresql+asyncpg://user:@localhost:5432/ai_team
DATABASE_URL_SYNC=postgresql://user:@localhost:5432/ai_team

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_key_here

# Environment
ENVIRONMENT=development
DEBUG=true

REDIS_URL=redis://localhost:6379/0

CLERK_JWKS_URL = 